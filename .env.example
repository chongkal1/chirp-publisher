# Google Drive (public folder + API key)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Blog API
BLOG_API_URL=https://your-site.vercel.app/api/blog
BLOG_API_KEY=chirp-blog-api-key-change-me

# Cron schedule (default: daily at 2 AM PST / 10 AM UTC)
CRON_SCHEDULE=0 10 * * *

# Railway Volume mount point for persistent data
DATA_DIR=/app/data

# Default blog settings
DEFAULT_CATEGORY_SLUG=news
DEFAULT_AUTHOR_ID=john-doe

# Server port
PORT=3000
